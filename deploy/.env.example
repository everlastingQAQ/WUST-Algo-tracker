# Copy this file to deploy/.env on the server and edit the values.

APP_ROOT=/opt/wust-algo
APP_USER=acm_tracker

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=cwxu
POSTGRES_PASSWORD=cwxu
POSTGRES_USER_DB=algo_user
POSTGRES_CORE_DB=algo_core_data

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=cwxu

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=cwxu-algo
RABBITMQ_PASSWORD=cwxu-algo
RABBITMQ_VHOST=algo

CONSUL_HOST=127.0.0.1
CONSUL_PORT=8500

USER_HTTP_ADDR=0.0.0.0:8000
USER_GRPC_ADDR=0.0.0.0:9000
CORE_HTTP_ADDR=0.0.0.0:8001
CORE_GRPC_ADDR=0.0.0.0:9001
AGENT_HTTP_ADDR=0.0.0.0:8002
AGENT_GRPC_ADDR=0.0.0.0:9002
GATEWAY_ADDR=127.0.0.1:8080

# Set to 1 only after ARK_* and SMTP_* are valid.
ENABLE_AGENT=0
ARK_MODEL=replace-with-volcengine-model-id
ARK_SECRET=replace-with-volcengine-api-key

SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=replace-with-email
SMTP_PASSWORD=replace-with-smtp-auth-code
SMTP_FROM=replace-with-email
